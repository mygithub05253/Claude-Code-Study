{
  "name": "@claude-code-study/explainer",
  "version": "0.0.1",
  "private": true,
  "description": "Claude Code 스킬의 한국어 해설 생성기 (MVP는 프롬프트 + 캐시만 제공, 호출은 Claude Code CLI 세션에서 수동)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
