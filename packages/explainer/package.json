    "generate": "tsx src/generate.ts"
  },
  "dependencies": {
    "@claude-code-study/parser": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
